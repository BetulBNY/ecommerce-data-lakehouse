[sqlfluff]
dialect = postgres
# Devre dışı bırakılan tüm 'titiz' kurallar:
exclude_rules = 
    layout.spacing, 
    layout.indent, 
    layout.long_lines, 
    layout.end_of_file, 
    references.keywords, 
    aliasing.table, 
    capitalisation.identifiers, 
    capitalisation.functions, 
    structure.simple_case,
    layout.select_targets,
    capitalisation.keywords,
    layout.keyword_newline,
    layout.cte_newline,
    structure.else_null

[sqlfluff:indentation]
tab_width = 4
indent_unit = space