[sqlfluff]
dialect = postgres
# We completely add and disable the rules that cause errors
# layout.spacing: Doesn't mind excessive spacing between columns (LT01)
# layout.indent: Doesn't take indentations too seriously (LT02)
# layout.long_lines: Doesn't mind line length (LT05)
# layout.end_of_file: Doesn't mind empty lines at the end of the file (LT12)
# references.keywords: Doesn't mind keywords like date and order (RF04)
exclude_rules = layout.spacing, layout.indent, layout.long_lines, layout.end_of_file, references.keywords, aliasing.table, capitalisation.identifiers

[sqlfluff:indentation]
tab_width = 4
indent_unit = space